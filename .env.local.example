# llama.cpp サーバーのURL（デフォルト: http://localhost:8080）
LLAMA_API_URL=http://localhost:8080

# 使用するモデル名（デフォルト: gemma4）
LLAMA_MODEL=gemma4

# --- tool calling（Web検索）の任意設定 ---
# 検索・取得のタイムアウト（ミリ秒、デフォルト: 8000）
# TOOL_FETCH_TIMEOUT_MS=8000
# 1ページから取り込む最大文字数（デフォルト: 4000）
# TOOL_MAX_TEXT_CHARS=4000
# エージェントループの最大反復回数（デフォルト: 5）
# TOOL_MAX_ITERATIONS=5
