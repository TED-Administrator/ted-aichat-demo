# docker-compose 用の環境変数ファイル
# このファイルを .env にコピーして使用してください
#
#   cp .env.example .env

# llama.cpp サーバーのURL
# ホストで動かしている場合は host.docker.internal を使用
LLAMA_API_URL=http://host.docker.internal:8080

# 使用するモデル名
LLAMA_MODEL=gemma4

# --- tool calling（Web検索）の任意設定 ---
# 検索・取得のタイムアウト（ミリ秒、デフォルト: 8000）
# TOOL_FETCH_TIMEOUT_MS=8000
# 1ページから取り込む最大文字数（デフォルト: 4000）
# TOOL_MAX_TEXT_CHARS=4000
# エージェントループの最大反復回数（デフォルト: 5）
# TOOL_MAX_ITERATIONS=5
